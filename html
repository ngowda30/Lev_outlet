<!DOCTYPE html>
<html>
<head>
    <title>Outlet Search Dashboard</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <style>
        body {
            font-family: Arial;
            background: #f5f6fa;
            text-align: center;
            margin: 0;
        }

        h2 {
            margin-top: 20px;
        }

        input {
            padding: 12px;
            width: 90%;
            max-width: 400px;
            border-radius: 8px;
            border: 1px solid #ccc;
            font-size: 16px;
        }

        #status {
            margin: 10px;
            font-size: 14px;
            color: gray;
        }

        table {
            margin-top: 10px;
            border-collapse: collapse;
            width: 95%;
            margin-left: auto;
            margin-right: auto;
            background: white;
            box-shadow: 0px 2px 8px rgba(0,0,0,0.1);
        }

        th {
            background: #273c75;
            color: white;
        }

        th, td {
            padding: 8px;
            border: 1px solid #ddd;
            font-size: 14px;
        }

        tr:hover {
            background-color: #f1f2f6;
        }

        button {
            margin-top: 10px;
            padding: 8px 15px;
            border: none;
            background: #44bd32;
            color: white;
            border-radius: 6px;
            cursor: pointer;
        }

    </style>
</head>

<body>

<h2>🔍 Outlet Search Dashboard</h2>

<input 
    type="text" 
    id="searchInput" 
    placeholder="Search Outlet ID / Name..."
    onkeyup="searchData()"
/>

<br>
<button onclick="loadData()">🔄 Refresh</button>

<div id="status">Loading...</div>

<table>
    <thead id="tableHead"></thead>
    <tbody id="tableBody"></tbody>
</table>

<script>

// ✅ YOUR LIVE API
const API_URL = "https://opensheet.elk.sh/17qYYhekFBD-KIoUTMPlXLm7sXXaXHcsYQK1v2R-FqV4/1";

let sheetData = [];

// 🚀 Load Data
async function loadData() {
    document.getElementById("status").innerText = "Loading latest data...";

    try {
        const res = await fetch(API_URL);
        sheetData = await res.json();

        if (!sheetData.length) {
            document.getElementById("status").innerText = "No data found ❌";
            return;
        }

        document.getElementById("status").innerText = "Data Loaded ✅";

        createHeader();
        displayData(sheetData);

    } catch (err) {
        document.getElementById("status").innerText = "Error loading data ❌";
        console.error(err);
    }
}

// 📊 Create Table Header
function createHeader() {
    const headers = Object.keys(sheetData[0]);
    let html = "<tr>";

    headers.forEach(h => {
        html += `<th>${h}</th>`;
    });

    html += "</tr>";
    document.getElementById("tableHead").innerHTML = html;
}

// 📊 Display Data
function displayData(data) {
    const body = document.getElementById("tableBody");
    body.innerHTML = "";

    if (data.length === 0) {
        body.innerHTML = "<tr><td colspan='100%'>No Results</td></tr>";
        return;
    }

    data.forEach(row => {
        let rowHTML = "<tr>";

        Object.values(row).forEach(val => {
            rowHTML += `<td>${val || ""}</td>`;
        });

        rowHTML += "</tr>";
        body.innerHTML += rowHTML;
    });
}

// 🔍 Search
function searchData() {
    const input = document.getElementById("searchInput").value.toLowerCase();

    const filtered = sheetData.filter(row =>
        Object.values(row).some(val =>
            String(val).toLowerCase().includes(input)
        )
    );

    displayData(filtered);
}

// 🔄 Auto refresh every 30 sec
setInterval(loadData, 30000);

// Load first time
loadData();

</script>

</body>
</html>
